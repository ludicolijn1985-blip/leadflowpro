generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  FREE
  PRO
}

enum TeamRole {
  ADMIN
  USER
}

enum TaskStatus {
  OPEN
  DONE
  CANCELED
}

enum TimelineType {
  EMAIL
  NOTE
  ACTIVITY
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
}

enum SequenceStatus {
  DRAFT
  ACTIVE
  PAUSED
}

model User {
  id               String                  @id @default(cuid())
  email            String                  @unique
  passwordHash     String
  role             Role                    @default(FREE)
  teamRole         TeamRole                @default(ADMIN)
  referralCode     String                  @unique
  referredBy       String?
  stripeCustomerId String?                 @unique
  trialStart       DateTime?
  trialEnd         DateTime?
  twoFactorEnabled Boolean                 @default(false)
  twoFactorSecret  String?
  locale           String                  @default("en")
  theme            String                  @default("dark")
  unsubscribedAt   DateTime?
  createdAt        DateTime                @default(now())
  referrer         User?                   @relation("UserReferrals", fields: [referredBy], references: [id])
  referrals        User[]                  @relation("UserReferrals")
  leads            Lead[]
  campaigns        Campaign[]
  pipelineStages   PipelineStage[]
  opportunities    Opportunity[]
  tasksAssigned    Task[]                  @relation("TaskAssignee")
  tasksCreated     Task[]                  @relation("TaskCreator")
  segments         SavedSegment[]
  workflows        Workflow[]
  dripSequences    DripSequence[]
  webhooks         OutgoingWebhook[]
  integrations     IntegrationConnection[]
  featureFlags     FeatureFlag[]
  auditLogs        AuditLog[]
  sessions         UserSession[]
  magicLinks       MagicLinkToken[]
  activities       ActivityEvent[]
  usageMetrics     UsageMetric[]
  consentRecords   ConsentRecord[]
  referralEarnings ReferralEarning[]       @relation("ReferrerEarnings")
  referredEarnings ReferralEarning[]       @relation("ReferredEarnings")
  invoices         InvoiceRecord[]
  stats            UserStats?
  milestones       Milestone?
}

model Lead {
  id            String          @id @default(cuid())
  userId        String
  stageId       String?
  name          String
  email         String
  status        String          @default("NEW")
  score         Int             @default(0)
  customFields  Json?
  duplicateKey  String?
  isDemo        Boolean         @default(false)
  followUpAt    DateTime?
  repliedAt     DateTime?
  createdAt     DateTime        @default(now())
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  stage         PipelineStage?  @relation(fields: [stageId], references: [id], onDelete: SetNull)
  opportunities Opportunity[]
  timeline      TimelineEvent[]
  tasks         Task[]
  segments      SegmentLead[]
  activities    ActivityEvent[]

  @@index([userId])
  @@index([stageId])
  @@index([duplicateKey])
  @@index([followUpAt])
}

model Campaign {
  id               String        @id @default(cuid())
  userId           String
  name             String
  subject          String
  body             String
  sentCount        Int           @default(0)
  openCount        Int           @default(0)
  clickCount       Int           @default(0)
  attributedAmount Float         @default(0)
  createdAt        DateTime      @default(now())
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  drips            DripStep[]
  activities       ActivityEvent[]

  @@index([userId])
}

model PipelineStage {
  id            String        @id @default(cuid())
  userId        String
  name          String
  color         String        @default("#06b6d4")
  sortOrder     Int
  isDefault     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads         Lead[]
  opportunities Opportunity[]

  @@unique([userId, sortOrder])
  @@index([userId])
}

model Opportunity {
  id        String            @id @default(cuid())
  userId    String
  leadId    String?
  stageId   String?
  name      String
  amount    Float             @default(0)
  status    OpportunityStatus @default(OPEN)
  closeDate DateTime?
  createdAt DateTime          @default(now())
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead      Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  stage     PipelineStage?    @relation(fields: [stageId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([leadId])
  @@index([stageId])
}

model TimelineEvent {
  id        String       @id @default(cuid())
  userId    String
  leadId    String
  type      TimelineType
  content   String
  metadata  Json?
  createdAt DateTime     @default(now())
  lead      Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([userId, leadId])
}

model SavedSegment {
  id        String        @id @default(cuid())
  userId    String
  name      String
  filters   Json
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  members   SegmentLead[]

  @@index([userId])
}

model SegmentLead {
  segmentId String
  leadId    String
  segment   SavedSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  lead      Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@id([segmentId, leadId])
}

model Task {
  id          String     @id @default(cuid())
  userId      String
  leadId      String?
  title       String
  description String?
  dueDate     DateTime?
  reminderAt  DateTime?
  status      TaskStatus @default(OPEN)
  createdAt   DateTime   @default(now())
  user        User       @relation("TaskAssignee", fields: [userId], references: [id], onDelete: Cascade)
  creator     User       @relation("TaskCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdBy   String
  lead        Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([createdBy])
}

model Workflow {
  id        String   @id @default(cuid())
  userId    String
  name      String
  trigger   String
  action    String
  config    Json
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DripSequence {
  id        String         @id @default(cuid())
  userId    String
  name      String
  status    SequenceStatus @default(DRAFT)
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps     DripStep[]

  @@index([userId])
}

model DripStep {
  id         String       @id @default(cuid())
  sequenceId String
  campaignId String?
  stepOrder  Int
  delayDays  Int          @default(0)
  emailBody  String?
  sequence   DripSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  campaign   Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@unique([sequenceId, stepOrder])
}

model OutgoingWebhook {
  id        String   @id @default(cuid())
  userId    String
  name      String
  endpoint  String
  secret    String?
  events    Json
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model IntegrationConnection {
  id        String   @id @default(cuid())
  userId    String
  provider  String
  config    Json
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, provider])
}

model FeatureFlag {
  id        String   @id @default(cuid())
  userId    String?
  key       String
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([key])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  resource  String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  tokenId   String   @unique
  ip        String?
  userAgent String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
}

model MagicLinkToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model ActivityEvent {
  id         String   @id @default(cuid())
  userId     String
  leadId     String?
  campaignId String?
  type       String
  message    String
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead       Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model UsageMetric {
  id        String   @id @default(cuid())
  userId    String
  monthKey  String
  emails    Int      @default(0)
  imports   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, monthKey])
}

model ConsentRecord {
  id           String   @id @default(cuid())
  userId       String
  email        String
  unsubscribed Boolean  @default(false)
  source       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
}

model ReferralEarning {
  id             String   @id @default(cuid())
  referrerId     String
  referredUserId String
  amount         Float    @default(0)
  currency       String   @default("EUR")
  createdAt      DateTime @default(now())
  referrer       User     @relation("ReferrerEarnings", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser   User     @relation("ReferredEarnings", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([referrerId])
}

model InvoiceRecord {
  id        String   @id @default(cuid())
  userId    String
  stripeId  String   @unique
  amount    Float
  currency  String   @default("eur")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WebhookEvent {
  id        String   @id
  createdAt DateTime @default(now())
}

model UserStats {
  id             String   @id @default(cuid())
  userId         String   @unique
  replies        Int      @default(0)
  campaignsSent  Int      @default(0)
  leadsImported  Int      @default(0)
  conversations  Int      @default(0)
  clients        Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Milestone {
  id            String   @id @default(cuid())
  userId        String   @unique
  firstReplyAt  DateTime?
  firstMeetingAt DateTime?
  firstClientAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}